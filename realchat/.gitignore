# ===============================
# 1. PYTHON & DJANGO
# ===============================
*.py[cod]
*.pyo
*.pyd
__pycache__/
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
*.manifest
*.spec

# Django migrations (UNCOMMENT if you want to ignore migrations, but NOT recommended)
# */migrations/
# !*/migrations/__init__.py

