# ===============================
venv/
env/
ENV/
.venv/
env/
.envs/
*.env.local
*.env

# ===============================
# 3. DATABASES (SQLite & PostgreSQL dumps)
# ===============================
db.sqlite3
*.sqlite3
*.dump
*.pgsql
dump.rdb          # Redis dump file

# ===============================
# 4. ENVIRONMENT VARIABLES (CRITICAL - DO NOT COMMIT)
# ===============================
.env
.env.local
.env.production
.env.development

# ===============================
